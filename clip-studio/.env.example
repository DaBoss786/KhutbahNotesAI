# Copy this file to .env, then fill in your local settings.
# The OpenAI key is read only by the backend. It is never sent to the browser.
OPENAI_API_KEY=

APP_HOST=127.0.0.1
APP_PORT=8787
DATABASE_PATH=data/khutbah_clips.sqlite
STORAGE_ROOT=.

OPENAI_MODEL=gpt-5.4-mini
WHISPER_MODEL=base

DEFAULT_CLIP_COUNT=5
DEFAULT_MIN_DURATION=20
DEFAULT_MAX_DURATION=60
INTRO_SECONDS=2
OUTRO_SECONDS=5

BRAND_NAME=Khutbah Notes
BRAND_PRIMARY=#125C40
BRAND_ACCENT=#2FB36D
BRAND_CREAM=#FAF8F0
BRAND_WATERMARK=Khutbah Notes
BRAND_LOGO_PATH=../Khutbah Notes AI/Assets.xcassets/KhutbahNotesLogo.imageset/Khutbah Notes logo 1024 x 1024.png
